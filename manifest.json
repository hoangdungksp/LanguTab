{
  "manifest_version": 3,
  "name": "LinguTab — Học tiếng Trung & Anh",
  "version": "1.7.7",
  "description": "Biến mỗi tab mới thành một buổi học tiếng Trung hoặc tiếng Anh. HSK1 150 từ · Oxford 500 từ · Pinyin & IPA chuẩn · Audio bản ngữ · FSRS spaced repetition · Sync ảnh flashcard qua Google Drive.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab/index.html"
  },
  "permissions": ["storage", "identity"],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*",
    "https://api.mymemory.translated.net/*"
  ],
  "oauth2": {
    "client_id": "138440772678-72fno6lo0dgtrk3fdfok9466n93fh861.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.appdata",
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  }
}
