{
  "name": "lingua-newtab",
  "displayName": "LinguTab — Học tiếng Trung & Anh",
  "version": "1.20.0",
  "versionName": "1.20.0 — Web dashboard (D-21): nền sync tiến độ + admin quản lý user",
  "description": "Chrome extension thay new tab thành nơi học tiếng Trung / tiếng Anh với phonetics, flashcard SRS, TTS. Dành cho người Việt.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "zip": "cd dist && zip -r ../lingua-newtab.zip . && cd ..",
    "worker:dev": "cd worker && wrangler dev",
    "worker:deploy": "cd worker && wrangler deploy",
    "validate:exam": "tsx scripts/validate-exam-data.ts",
    "prebuild": "npm run validate:exam"
  },
  "dependencies": {
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "ts-fsrs": "^4.6.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.22.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
