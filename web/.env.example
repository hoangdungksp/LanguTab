# Copy to .env.local and fill in. Vite exposes VITE_* to the client.

# Google OAuth *Web* client ID (console.cloud.google.com → Credentials →
# OAuth client → Web application). Add your web origins to "Authorized
# JavaScript origins": http://localhost:5173 and https://<your>.pages.dev
# (and https://lingutab.com later).
VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Worker API base (shared with the extension).
VITE_WORKER_URL=https://lingua-newtab-worker.kspstudio.workers.dev
